# ============================================================
#  Pila de correo — copia este archivo como .env y ajusta
# ============================================================

# Dominio principal del correo (se usa en hostname y DEFAULT_DOMAIN del panel)
MAIL_DOMAIN=adpublicidad.co

# Red local permitida para envío (Postfix mynetworks)
PERMIT_MYNETWORKS=192.168.1.0/24

# ------------------------------------------------------------
# Base de datos MariaDB (solo la usa Roundcube)
# ------------------------------------------------------------
DB_ROOT_PASSWORD=RootSuperSecreta2026.
DB_NAME=webmail_db
DB_USER=roundcube
DB_PASSWORD=RoundcubeSegura2026.

# ------------------------------------------------------------
# Credenciales del panel MailAdmin (http://IP:8889)
# ------------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=CambiaEstaClave2026.
